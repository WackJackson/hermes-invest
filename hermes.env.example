# Hermes runtime
OPENAI_API_KEY=replace-me
# Or use one of Hermes-supported providers instead of OpenAI.

# Feishu / Lark
FEISHU_APP_ID=replace-me
FEISHU_APP_SECRET=replace-me
FEISHU_CONNECTION_MODE=websocket
# Optional for webhook mode:
# FEISHU_ENCRYPT_KEY=replace-me
# FEISHU_VERIFICATION_TOKEN=replace-me
# FEISHU_HOME_CHANNEL=replace-me

# Hermes MCP bridge to investment core
INVEST_DB_PATH=/opt/hermes-invest/data/investment_core.db
INVEST_CORE_BASE_URL=http://127.0.0.1:18080
